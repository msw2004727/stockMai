# ---- Data source ----
FINMIND_TOKEN=

# ---- Database ----
POSTGRES_DB=twstock
POSTGRES_USER=twstock_user
POSTGRES_PASSWORD=twstock_pass
DATABASE_URL=postgresql://twstock_user:twstock_pass@localhost:5432/twstock
REDIS_URL=redis://localhost:6379/0

# ---- AI API Keys ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROK_API_KEY=
GEMINI_API_KEY=

# ---- AI Gateway ----
AI_DAILY_BUDGET_USD=5.0
AI_TIMEOUT_SECONDS=15
AI_RETRY_COUNT=2
AI_RETRY_BACKOFF_SECONDS=0.35
AI_DEFAULT_PROVIDERS=claude,gpt5,grok,gemini
AI_PROVIDER_WEIGHTS=claude=1.0,gpt5=1.0,grok=1.0,gemini=1.0

# ---- Model config ----
CLAUDE_MODEL=claude-opus-4-6
GPT_MODEL=gpt-5.2
GROK_MODEL=grok-4.1-fast
GEMINI_MODEL=gemini-3.1-pro-preview

# ---- Other ----
PREDICTION_HORIZON=1
CONFIDENCE_THRESHOLD=0.60
JWT_SECRET=change_me
JWT_EXPIRE_MINUTES=60
API_DAILY_LIMIT=200
CORS_ALLOW_ORIGINS=*
